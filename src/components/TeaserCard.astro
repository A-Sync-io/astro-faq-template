---
import type { CollectionEntry } from 'astro:content';

interface Props {
  faq: CollectionEntry<'faq'>;
  variant?: 'default' | 'compact';
}

const { faq, variant = 'default' } = Astro.props;
const { title, category, description } = faq.data;
---

<article class:list={['teaser', { 'teaser--compact': variant === 'compact' }]}>
  <a href={`/faq/${faq.slug}`} class="teaser-link">
    <div class="teaser-image">
      <div class="teaser-placeholder">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <!-- Colored bottom strip like DI Digital -->
      <div class="teaser-strip"></div>
    </div>
    
    <div class="teaser-content">
      <span class="teaser-category">{category}</span>
      <h2 class="teaser-title">{title}</h2>
      {variant !== 'compact' && <p class="teaser-description">{description}</p>}
    </div>
  </a>
</article>

<style>
  .teaser {
    position: relative;
  }

  .teaser-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .teaser-link:hover {
    text-decoration: none;
  }

  .teaser-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-secondary);
  }

  .teaser-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .teaser-placeholder svg {
    width: 48px;
    height: 48px;
  }

  .teaser-link:hover .teaser-placeholder svg {
    color: var(--color-primary);
    transform: scale(1.05);
    transition: all 0.3s ease;
  }

  /* Colored bottom strip - DI Digital style */
  .teaser-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--color-primary);
    border-radius: 0 0 var(--radius-md) var(--radius-md);
  }

  .teaser-content {
    padding: var(--space-md) 0;
  }

  .teaser-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .teaser-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .teaser-link:hover .teaser-title {
    color: var(--color-primary);
  }

  .teaser-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Compact variant */
  .teaser--compact .teaser-image {
    aspect-ratio: 4 / 3;
  }

  .teaser--compact .teaser-title {
    font-size: 1rem;
  }
</style>
