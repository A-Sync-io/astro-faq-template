---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'faq'>;
  expanded?: boolean;
}

const { item, expanded = false } = Astro.props;
const { title, category, tags } = item.data;

const href = `/faq/${item.slug}`;
---

<article class="bg-white dark:bg-slate-800 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-md transition-shadow">
  <div class="p-6">
    <div class="flex items-start justify-between mb-3">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
        {category}
      </span>
      
      {expanded && (
        <a href={href} class="text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" aria-label="Open question">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      )}
    </div>
    
    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">
      <a href={href} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        {title}
      </a>
    </h3>
    
    {expanded ? (
      <div class="prose prose-slate dark:prose-invert prose-sm max-w-none mb-4">
        <slot />
      </div>
    ) : (
      <p class="text-slate-600 dark:text-slate-300 text-sm mb-4 line-clamp-2">
        {item.data.description}
      </p>
    )}
    
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-700 px-2 py-1 rounded">
          #{tag}
        </span>
      ))}
    </div>
  </div>
</article>
