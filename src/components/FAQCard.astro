---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'faq'>;
  expanded?: boolean;
}

const { item, expanded = false } = Astro.props;
const { title, category, tags } = item.data;

const href = `/faq/${item.slug}`;
---

<article class="card card-interactive h-full">
  <div class="p-6">
    
    {/* Category Tag */}
    <div class="mb-4">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-[var(--color-primary-50)] text-[var(--color-primary)] border border-[var(--color-primary-100)]">
        {category}
      </span>
    </div>
    
    {/* Title */}
    <h3 class="text-lg font-bold text-[var(--color-text-primary)] mb-3 line-clamp-2">
      <a href={href} class="hover:text-[var(--color-primary)] transition-colors">
        {title}
      </a>
    </h3>
    
    {/* Description / Content */}
    {expanded ? (
      <div class="prose prose-sm max-w-none mb-4 text-[var(--color-text-secondary)]">
        <slot />
      </div>
    ) : (
      <p class="text-[0.9375rem] text-[var(--color-text-secondary)] mb-4 line-clamp-2">
        {item.data.description}
      </p>
    )}
    
    {/* Footer */}
    <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border-light)]">
      
      {/* Tags */}
      <div class="flex flex-wrap gap-2">
        {tags.slice(0, 2).map((tag) => (
          <span class="text-xs text-[var(--color-text-tertiary)] bg-[var(--color-bg-secondary)] px-2 py-1 rounded-md">
            {tag}
          </span>
        ))}
      </div>
      
      {/* Read More Link */}
      <a 
        href={href} 
        class="text-sm font-semibold text-[var(--color-primary)] hover:text-[var(--color-primary-700)] flex items-center gap-1 transition-colors"
      >
        Read
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</article>
