---
import { SITE, NAV } from '../config';
import FaqBubble from './FaqBubble.astro';
---

<footer class="bg-zinc-950 text-zinc-100 mt-16 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Column 1: Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xl font-bold tracking-tight text-white">{SITE.name}</span>
          <FaqBubble class="h-8 w-auto [&>svg]:h-full [&>svg]:w-auto" />
        </div>
        <p class="text-sm text-zinc-400 leading-relaxed">{SITE.description}</p>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">Quick Links</h3>
        <ul class="space-y-3">
          {NAV.main.map((item) => (
            <li><a href={item.href} class="text-sm text-zinc-400 hover:text-white transition-colors">{item.label}</a></li>
          ))}
          <li><a href="/search" class="text-sm text-zinc-400 hover:text-white transition-colors">Search</a></li>
        </ul>
      </div>

      <!-- Column 3: Categories -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">Categories</h3>
        <ul class="space-y-3">
          <li><a href="/faq" class="text-sm text-zinc-400 hover:text-white transition-colors">Getting Started</a></li>
          <li><a href="/faq" class="text-sm text-zinc-400 hover:text-white transition-colors">Customization</a></li>
          <li><a href="/faq" class="text-sm text-zinc-400 hover:text-white transition-colors">Content Management</a></li>
          <li><a href="/categories" class="text-sm text-zinc-400 hover:text-white transition-colors">All Categories</a></li>
        </ul>
      </div>

      <!-- Column 4: Support -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">Support</h3>
        <ul class="space-y-3">
          <li><a href="/faq" class="text-sm text-zinc-400 hover:text-white transition-colors">Help Center</a></li>
          <li><a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Contact Us</a></li>
          <li><a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="#" class="text-sm text-zinc-400 hover:text-white transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-zinc-800 text-center text-sm text-zinc-500">
      <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
