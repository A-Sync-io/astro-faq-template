---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { SITE } from '../../config';

const allFAQs = await getCollection('faq', ({ data }) => !data.draft);
const sortedFAQs = allFAQs.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Load content for accordion
const faqsWithContent = await Promise.all(
  sortedFAQs.map(async (faq) => {
    const { Content } = await faq.render();
    return { ...faq, Content };
  })
);

const totalFAQs = allFAQs.length;
const categories = [...new Set(allFAQs.map((faq) => faq.data.category))];
---

<Layout 
  seo={{
    title: `All Questions (${totalFAQs}) - ${SITE.name}`,
    description: `Explore our complete collection of ${totalFAQs} frequently asked questions.`,
    type: 'website'
  }}
  <!-- Page Header -->
  <section class="bg-[var(--color-secondary)] text-[var(--color-text-inverted)] py-16 md:py-20">
    <div class="container">
      <nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-inverted)] transition-colors">Home</a>
        <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        
        <span class="text-[var(--color-primary)]">All Questions</span>
      </nav>
      
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <span class="label-text text-[var(--color-text-tertiary)] mb-2 block">Knowledge Base</span>
          <h1 class="editorial-title text-[var(--color-text-inverted)]">All Questions</h1>
          <p class="text-[var(--color-text-tertiary)] text-lg mt-4">{totalFAQs} frequently asked questions</p>
        </div>
        
        <a 
          href="/search" 
          class="btn btn-secondary border-[var(--color-secondary-lighter)] text-[var(--color-text-inverted)] hover:bg-[var(--color-secondary-lighter)]"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Search
        </a>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="border-b border-[var(--color-border-light)] bg-[var(--color-bg-primary)]">
    <div class="container py-4">
      <div class="flex items-center gap-3 overflow-x-auto scrollbar-hide">
        <span class="text-sm font-medium text-[var(--color-text-tertiary)] flex-shrink-0">Filter:</span>
        
        <a 
          href="/faq" 
          class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold bg-[var(--color-primary)] text-white"
        >
          All
        </a>
        
        {categories.map((category) => (
          <a 
            href={`/categories/${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium text-[var(--color-text-secondary)] bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg-tertiary)] transition-colors"
          >
            {category}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="py-12 md:py-16 bg-[var(--color-bg-secondary)]">
    <div class="container max-w-4xl">
      <FAQAccordion faqs={faqsWithContent} />
    </div>
  </section>
</Layout>
