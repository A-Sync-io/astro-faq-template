---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FAQCard from '../../components/FAQCard.astro';

// Generate static paths for all FAQs
export async function getStaticPaths() {
  const faqs = await getCollection('faq', ({ data }) => !data.draft);
  
  return faqs.map((faq) => ({
    params: { slug: faq.slug },
    props: { faq }
  }));
}

const { faq } = Astro.props;
const { Content } = await faq.render();

// Get related FAQs (same category)
const relatedFAQs = await getCollection('faq', ({ 
  data, 
  slug 
}) => 
  !data.draft && 
  slug !== faq.slug && 
  data.category === faq.data.category
).then(faqs => faqs.slice(0, 3));
---

<Layout 
  seo={{
    title: `${faq.data.title} - FAQ`,
    description: faq.data.description,
    type: 'article',
    pubDate: faq.data.pubDate,
    modifiedDate: faq.data.updatedDate,
    tags: faq.data.tags,
    canonicalURL: faq.data.canonicalURL
  }}
>
  <!-- Article Header -->
  <section class="bg-card border-b border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-muted-foreground hover:text-foreground transition-colors">Home</a>
        <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        
        <a href="/faq" class="text-muted-foreground hover:text-foreground transition-colors">FAQ</a>
        <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        
        <span class="text-primary font-medium truncate max-w-[200px] sm:max-w-xs">{faq.data.title}</span>
      </nav>
      
      <div class="max-w-3xl">
        <div class="mb-6">
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold bg-primary/10 text-primary border border-primary/20">
            {faq.data.category}
          </span>
        </div>
        
        <h1 class="text-3xl md:text-5xl font-extrabold text-foreground tracking-tight mb-6">{faq.data.title}</h1>
        
        <p class="text-xl text-muted-foreground leading-relaxed">{faq.data.description}</p>
        
        <div class="flex flex-wrap items-center gap-4 mt-8 text-sm text-muted-foreground">
          <time datetime={faq.data.pubDate.toISOString()} class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {faq.data.pubDate.toLocaleDateString()}
          </time>
          
          {faq.data.updatedDate && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
              Updated: {faq.data.updatedDate.toLocaleDateString()}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg prose-slate dark:prose-invert max-w-none">
          <Content />
        </div>
        
        <!-- Tags -->
        {faq.data.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-border">
            <h3 class="text-sm font-bold uppercase tracking-wider text-muted-foreground mb-4">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {faq.data.tags.map((tag) => (
                <a 
                  href={`/tag/${tag.toLowerCase()}`}
                  class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-muted text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </article>

  <!-- Related FAQs -->
  {relatedFAQs.length > 0 && (
    <section class="py-12 md:py-16 bg-muted/30 border-t border-border">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <span class="text-sm font-bold uppercase tracking-wider text-primary mb-2 block">You might also like</span>
          <h2 class="text-3xl font-bold text-foreground mb-8">Related Questions</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedFAQs.map((related) => (
              <FAQCard item={related} />
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
</Layout>