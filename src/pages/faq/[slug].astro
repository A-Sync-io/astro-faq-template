---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FAQCard from '../../components/FAQCard.astro';

// Generate static paths for all FAQs
export async function getStaticPaths() {
  const faqs = await getCollection('faq', ({ data }) => !data.draft);
  
  return faqs.map((faq) => ({
    params: { slug: faq.slug },
    props: { faq }
  }));
}

const { faq } = Astro.props;
const { Content } = await faq.render();

// Get related FAQs (same category)
const relatedFAQs = await getCollection('faq', ({ 
  data, 
  slug 
}) => 
  !data.draft && 
  slug !== faq.slug && 
  data.category === faq.data.category
).then(faqs => faqs.slice(0, 3));
---

<Layout 
  seo={{
    title: `${faq.data.title} - FAQ`,
    description: faq.data.description,
    type: 'article',
    pubDate: faq.data.pubDate,
    modifiedDate: faq.data.updatedDate,
    tags: faq.data.tags,
    canonicalURL: faq.data.canonicalURL
  }}
003e
  <!-- Article Header -->
  <section class="bg-[var(--color-bg-secondary)] border-b border-[var(--color-border-light)]">
    <div class="container py-12 md:py-16">
      <nav class="flex items-center gap-2 text-sm mb-6" aria-label="Breadcrumb">
        <a href="/" class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)] transition-colors">Home</a>
        <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        
        <a href="/faq" class="text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)] transition-colors">FAQ</a>
        <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        
        <span class="text-[var(--color-primary)] font-medium truncate max-w-[200px] sm:max-w-xs">{faq.data.title}</span>
      </nav>
      
      <div class="max-w-3xl">
        <div class="mb-6">
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-semibold bg-[var(--color-primary-50)] text-[var(--color-primary)] border border-[var(--color-primary-100)]">
            {faq.data.category}
          </span>
        </div>
        
        <h1 class="editorial-title mb-6">{faq.data.title}</h1>
        
        <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed">{faq.data.description}</p>
        
        <div class="flex flex-wrap items-center gap-4 mt-8 text-sm text-[var(--color-text-tertiary)]">
          <time datetime={faq.data.pubDate.toISOString()} class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {faq.data.pubDate.toLocaleDateString()}
          </time>
          
          {faq.data.updatedDate && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
              Updated: {faq.data.updatedDate.toLocaleDateString()}
            </span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-12 md:py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
        
        <!-- Tags -->
        {faq.data.tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-[var(--color-border-light)]">
            <h3 class="label-text mb-4">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {faq.data.tags.map((tag) => (
                <a 
                  href={`/tag/${tag.toLowerCase()}`}
                  class="inline-flex items-center px-3 py-1.5 rounded-lg text-sm font-medium bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-primary-50)] hover:text-[var(--color-primary)] transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}
        
        <!-- Share -->
        <div class="mt-8 pt-8 border-t border-[var(--color-border-light)]">
          <h3 class="label-text mb-4">Share this article</h3>
          
          <div class="flex items-center gap-3">
            <button 
              class="p-2.5 rounded-lg bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-primary)] hover:text-white transition-colors"
              onclick={`navigator.share({title: '${faq.data.title}', url: window.location.href})`}
              aria-label="Share"
003e
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
              </svg>
            </button>
            
            <button 
              class="p-2.5 rounded-lg bg-[var(--color-bg-secondary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-primary)] hover:text-white transition-colors"
              onclick="navigator.clipboard.writeText(window.location.href)"
              aria-label="Copy link"
003e
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- Related FAQs -->
  {relatedFAQs.length > 0 && (
    <section class="py-12 md:py-16 bg-[var(--color-bg-secondary)] border-t border-[var(--color-border-light)]">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <span class="label-text mb-2 block">You might also like</span>
          <h2 class="section-title mb-8">Related Questions</h2>
          
          <div class="space-y-4">
            {relatedFAQs.map((related) => (
              <FAQCard item={related} />
            ))}
          </div>
        </div>
      </div>
    </section>
  )}</Layout>
