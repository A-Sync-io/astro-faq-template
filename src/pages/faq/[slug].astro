---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FAQCard from '../../components/FAQCard.astro';

// Generate static paths for all FAQs
export async function getStaticPaths() {
  const faqs = await getCollection('faq', ({ data }) => !data.draft);
  
  return faqs.map((faq) => ({
    params: { slug: faq.slug },
    props: { faq }
  }));
}

const { faq } = Astro.props;
const { Content } = await faq.render();

// Get related FAQs (same category)
const relatedFAQs = await getCollection('faq', ({ 
  data, 
  slug 
}) => 
  !data.draft && 
  slug !== faq.slug && 
  data.category === faq.data.category
).then(faqs => faqs.slice(0, 3));
---

<Layout 
  seo={{
    title: `${faq.data.title} - FAQ`,
    description: faq.data.description,
    type: 'article',
    pubDate: faq.data.pubDate,
    modifiedDate: faq.data.updatedDate,
    tags: faq.data.tags,
    canonicalURL: faq.data.canonicalURL
  }}
003e
  <!-- Article Header -->
  <section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm mb-4" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 flex-wrap">
          <li>
            <a href="/" class="text-slate-400 hover:text-white transition-colors">Home</a>
          </li>
          <li class="text-slate-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </li>
          <li>
            <a href="/faq" class="text-slate-400 hover:text-white transition-colors">FAQ</a>
          </li>
          <li class="text-slate-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </li>
          <li class="text-blue-400">{faq.data.title}</li>
        </ol>
      </nav>
      
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-500/20 text-blue-300">
        {faq.data.category}
      </span>
      
      <h1 class="text-3xl md:text-4xl font-bold mt-4">{faq.data.title}</h1>
      
      <p class="text-lg text-slate-300 mt-4">{faq.data.description}</p>
      
      <div class="flex flex-wrap items-center gap-4 mt-6 text-sm text-slate-400">
        <time datetime={faq.data.pubDate.toISOString()}>
          Published: {faq.data.pubDate.toLocaleDateString()}
        </time>
        
        {faq.data.updatedDate && (
          <time datetime={faq.data.updatedDate.toISOString()}>
            Updated: {faq.data.updatedDate.toLocaleDateString()}
          </time>
        )}
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <article class="py-12 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg prose-slate dark:prose-invert max-w-none">
        <Content />
      </div>
      
      <!-- Tags -->
      <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
        <h3 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-4">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {faq.data.tags.map((tag) => (
            <a 
              href={`/tag/${tag.toLowerCase()}`}
              class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-blue-100 dark:hover:bg-blue-900 hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
      
      <!-- Share -->
      <div class="mt-8">
        <h3 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-4">Share</h3>
        <div class="flex items-center gap-3">
          <button 
            class="p-2 text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors"
            onclick={`navigator.share({title: '${faq.data.title}', url: window.location.href})`}
            aria-label="Share"
003e
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
            </svg>
          </button>
          
          <button 
            class="p-2 text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors"
            onclick="navigator.clipboard.writeText(window.location.href)"
            aria-label="Copy link"
003e
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </article>

  <!-- Related FAQs -->
  {relatedFAQs.length > 0 && (
    <section class="py-12 bg-slate-50 dark:bg-slate-800/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">
          Related Questions
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedFAQs.map((related) => (
            <FAQCard item={related} />
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
