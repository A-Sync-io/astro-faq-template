---
import type { SEOProps } from '../types';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config';
import '../styles/global.css';

interface Props {
  seo?: Partial<SEOProps>;
}

const { seo = {} } = Astro.props;

const defaultSEO: SEOProps = {
  title: SITE.title,
  description: SITE.description,
  type: 'website'
};

const mergedSEO = { ...defaultSEO, ...seo };
---

<!DOCTYPE html>
<html lang={SITE.language} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO {...mergedSEO} />
    
    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#0f172a" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <div class="flex flex-col min-h-screen">
      <Header />
      
      <main id="main-content" class="flex-grow" role="main">
        <slot />
      </main>
      
      <Footer />
    </div>
    
    <!-- Analytics placeholder - replace GA_MEASUREMENT_ID with your ID -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'GA_MEASUREMENT_ID', {
        'send_page_view': true,
        'cookie_flags': 'SameSite=None;Secure',
        'anonymize_ip': true
      });
    </script>
  </body>
</html>
